# AICatchy — Environment Variables
# Copy to .env.local at repo root

# ── Supabase ───────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:[password]@[host]:[port]/[database]?ssl-mode=require
SUPABASE_URL=https://[your-project].supabase.co
SUPABASE_ANON_KEY=[your-anon-key]
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]

# ── Web (Next.js App Router) ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[your-project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_APP_URL=https://[your-app].vercel.app
NEXT_PUBLIC_API_URL=https://[your-api].vercel.app

# ── API (tRPC + Hono) ──────────────────────────────────────────────
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,https://[your-web-app].vercel.app

# ── Shared Services ────────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
OPENAI_API_KEY=

# ── Jobs (PgBoss) ──────────────────────────────────────────────────
BOSS_MODE=database
MAX_WORKERS=1
LOG_LEVEL=info

# ── Admin ──────────────────────────────────────────────────────────
# Override NEXT_PUBLIC_APP_URL in apps/admin/.env.local (port 3001)
# All other vars shared from above
