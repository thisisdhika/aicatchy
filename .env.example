# ==============================================================================
# AICatchy MLP - Environment Configuration Template
# ==============================================================================
# Copy this file to .env.local for local development.
# Secure credentials must be set directly in the hosting provider (Vercel/Supabase)
# for production environments.
# ==============================================================================

# ------------------------------------------------------------------------------
# App & Environment
# ------------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Database & Authentication (Supabase)
# ------------------------------------------------------------------------------
# Public URL and Anonymous Key for client-side Supabase SDK initialization
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Server-only service role key (bypass Row Level Security, use with caution)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# Direct PostgreSQL connection string (useful for migrations and direct DB scripts)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# ------------------------------------------------------------------------------
# Large Language Model (OpenAI API)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-yourOpenAiApiKeyHere
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1024

# ------------------------------------------------------------------------------
# Affiliate Providers
# ------------------------------------------------------------------------------
# Shopee Affiliate Program Credentials (API v1)
SHOPEE_PARTNER_ID=your_shopee_partner_id
SHOPEE_PARTNER_KEY=your_shopee_partner_secret_key_never_expose

# Involve Asia Publisher Credentials (Dashboard / Deeplink resolver)
INVOLVE_ASIA_PUBLISHER_ID=your_involve_asia_publisher_id
INVOLVE_ASIA_API_KEY=your_involve_asia_api_key_if_used

# ------------------------------------------------------------------------------
# Telemetry & Product Analytics (PostHog)
# ------------------------------------------------------------------------------
# PostHog API token and host (use EU/US region or self-hosted endpoint)
NEXT_PUBLIC_POSTHOG_KEY=phc_yourPostHogPublicKeyHere
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
