# AICatchy — Environment Variables
# Copy to .env and fill in values

# ── Shared: Supabase Postgres (Drizzle) ──────────────────────────
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Shared: PostHog (server-side) ─────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── apps/web — Next.js client-side (NEXT_PUBLIC_*) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon-key]
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── apps/api — Hono/tRPC server ───────────────────────────────────
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,https://[web-app].vercel.app

# ── Vercel-only (set via `vercel env add`, kept here for reference) ─
SUPABASE_URL=https://[project].supabase.co
SUPABASE_ANON_KEY=[anon-key]
SUPABASE_SERVICE_ROLE_KEY=[service-role-key]
