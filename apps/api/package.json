{
  "name": "api",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/dev.ts",
    "build": "tsc -b && esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:@hono/node-server --external:tsx",
    "start": "tsx src/dev.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "hono": "^4.3.2",
    "@hono/trpc-server": "^0.4.2",
    "@trpc/server": "^11.4.2",
    "@trpc/client": "^11.4.2",
    "drizzle-orm": "^0.36.4",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "zod": "^3.23.8",
    "postgres": "^3.4.9",
    "pg": "^8.13.0",
    "@hono/node-server": "^1.0.0",
    "posthog-node": "^4.0.0",
    "pg-boss": "^12.0.2",
    "tsx": "^4.9.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "drizzle-kit": "^0.31.10",
    "@types/pg": "^8.11.6",
    "esbuild": "^0.25.0"
  },
  "exports": {
    ".": {
      "import": "./src/index.js"
    }
  }
}
